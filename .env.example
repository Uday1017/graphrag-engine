# ── LLM API Keys ─────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here        # console.groq.com
GOOGLE_API_KEY=your_gemini_api_key_here    # aistudio.google.com (optional)
MISTRAL_API_KEY=your_mistral_api_key_here  # console.mistral.ai (optional)

# ── Vector DB ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=research_papers

# ── Neo4j AuraDB ─────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=your_neo4j_username
NEO4J_PASSWORD=your_neo4j_password

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/graphrag

# ── App Config ───────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
TOP_K_RETRIEVAL=10
